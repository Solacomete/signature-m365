<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.5" xsi:type="MailApp">
  <Id>12345678-abcd-1234-abcd-1234567890ab</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>DSI Interne</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="Signatures Dynamiques" />
  <Description DefaultValue="Gestion centralisée des signatures" />
  <Hosts><Host Name="Mailbox" /></Hosts>
  <Requirements><Sets><Set Name="Mailbox" MinVersion="1.10" /></Sets></Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://solacomete.github.io/signature-m365/signature.js" />
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
    <Requirements><bt:Sets DefaultMinVersion="1.10"><bt:Set Name="Mailbox" /></bt:Sets></Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnNewMessageCompose" FunctionName="insertSignature" />
              <LaunchEvent Type="OnMessageReply" FunctionName="insertSignature" />
            </LaunchEvents>
            <SourceLocation resid="JSRuntime.Url" />
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Urls>
        <bt:Url id="JSRuntime.Url" DefaultValue="https://VOTRE_COMPTE.github.io/VOTRE_DEPOT/signature.js" />
      </bt:Urls>
    </Resources>
  </VersionOverrides>
</OfficeApp>
